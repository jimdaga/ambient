{
  "schedule": "0 10 * * 1",
  "displayName": "Helm Dependency Audit",
  "suspend": false,
  "reuseLastSession": false,
  "sessionTemplate": {
    "initialPrompt": "Run the helm dependency audit workflow.",
    "displayName": "Helm Dependency Audit",
    "llmSettings": {
      "model": "claude-sonnet-4-5",
      "temperature": 0,
      "maxTokens": 8192
    },
    "timeout": 2400,
    "inactivityTimeout": 300,
    "stopOnRunFinished": true,
    "repos": [
      {
        "url": "https://github.com/jimdaga/ambient",
        "branch": "main",
        "autoPush": true
      },
      {
        "url": "https://github.com/openshift-online/gcp-hcp-infra",
        "branch": "main",
        "autoPush": false
      }
    ],
    "activeWorkflow": {
      "gitUrl": "https://github.com/jimdaga/ambient",
      "branch": "main",
      "path": "workflows/helm-dependency-audit"
    }
  }
}
